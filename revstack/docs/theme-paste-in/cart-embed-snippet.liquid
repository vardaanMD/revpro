{% comment %}
  Custom cart embed — paste into theme as snippet, include in layout (e.g. theme.liquid before </body>).
  No Shopify app install required. Widget loads from Shopify CDN and calls the decision endpoint directly.

  Setup:
  1. Set SINGLE_SITE_TOKEN and SINGLE_SITE_SHOP env vars on Railway and redeploy.
  2. Replace REPLACE_WITH_SINGLE_SITE_TOKEN below with that token value.
  3. Upload cart-pro-v3.js to Shopify theme assets.
  4. Render this snippet in layout/theme.liquid before </body>: {% render 'custom-cart' %}
  5. Do NOT enable "Cart Pro V3" in App embeds.
  6. To suppress your theme's native cart drawer, inspect the drawer element in DevTools and
     set merchantCartDrawerSelector below (e.g. "#cart-notification", ".cart-drawer", etc.)
{% endcomment %}
<div id="cart-pro-root"></div>
<script>
(function() {
  if (window.__CART_PRO_EMBED_INIT__) return;
  window.__CART_PRO_EMBED_INIT__ = true;

  window.__CART_PRO_SNAPSHOT__ = {
    version: "3.0.0",
    runtimeVersion: "v3",
    currency: {{ cart.currency.iso_code | default: 'USD' | json }},

    // Direct backend connection — no Shopify app proxy needed
    directApi: {
      url: "https://revpro-production.up.railway.app/api/cart-decision",
      token: "6e3d9b2fa4de2eb788d2cbc4a916f3f7983fcf244c4053d869dd1f77976e5106"
    },

    appearance: {
      primaryColor: "#333333",
      accentColor: "#16a34a",
      borderRadius: 12,
      backgroundColor: "#ffffff",
      bannerBackgroundColor: "#16a34a",
      showConfetti: false,
      countdownEnabled: false,
      emojiMode: false,
      showHeaderBanner: false,
      cartHeaderMessages: [],
      showStickyCartButton: true,
      // Set this to suppress your theme's native cart drawer. Inspect the drawer
      // element in browser DevTools to find the right selector.
      // Examples: "#cart-notification", ".cart-drawer", "[id*='cart-drawer']"
      merchantCartDrawerSelector: ""
    },

    featureFlags: {
      enableUpsell: true,
      enableRewards: false,
      enableDiscounts: true,
      enableFreeGifts: false,
      enableCheckoutOverride: false,
      enableAnalytics: false
    },

    rewards: {
      tiers: [
        { thresholdCents: 2000, label: "10% OFF", rewardType: "discount" },
        { thresholdCents: 5000, label: "Free shipping!", rewardType: "shipping" }
      ],
      milestones: []
    },
    discounts: { allowStacking: false, whitelist: [] },
    freeGifts: { rules: [] },

    upsell: {
      standardRules: [],
      ai: { enabled: false },
      recommendationsHeading: "You might also like"
    },

    checkout: { mode: "default", overlay: { enabled: false } },
    analytics: { enabled: false },

    freeShipping: {
      enabled: true,
      thresholdCents: 5000
    },

    // Static fallback recommendations shown before/when decision API responds.
    recommendations: [],
    recommendationsByCollection: {},
    productToCollections: {}
  };

  var script = document.createElement('script');
  script.src = {{ 'cart-pro-v3.js' | asset_url | json }};
  script.defer = true;
  document.body.appendChild(script);
})();
</script>
