{
  "name": "revstack",
  "private": true,
  "scripts": {
    "build": "prisma generate && react-router build",
    "dev": "PORT=3000 SHOPIFY_APP_URL=https://app.revenity.io shopify app dev --tunnel-url=https://app.revenity.io",
    "dev:random": "shopify app dev",
    "config:link": "shopify app config link",
    "generate": "shopify app generate",
    "deploy": "shopify app deploy",
    "config:use": "shopify app config use",
    "env": "shopify app env",
    "start": "tsx server.ts",
    "docker-start": "npx prisma migrate deploy && npm run start",
    "setup": "prisma generate",
    "migrate:dev": "prisma migrate dev",
    "migrate:deploy": "prisma migrate deploy",
    "lint": "eslint --ignore-path .gitignore --cache --cache-location ./node_modules/.cache/eslint .",
    "shopify": "shopify",
    "prisma": "prisma",
    "graphql-codegen": "graphql-codegen",
    "vite": "vite",
    "typecheck": "react-router typegen && tsc --noEmit",
    "load:test": "NODE_ENV=development DEV_SKIP_PROXY=1 npx tsx scripts/load-test-decision.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "type": "module",
  "engines": {
    "node": ">=20.19 <22 || >=22.12"
  },
  "dependencies": {
    "@mjackson/node-fetch-server": "^0.7.0",
    "@prisma/client": "^6.16.3",
    "@react-router/dev": "^7.12.0",
    "@react-router/express": "^7.12.0",
    "@react-router/fs-routes": "^7.12.0",
    "@react-router/node": "^7.12.0",
    "@react-router/serve": "^7.12.0",
    "@revpro/decision-engine": "file:packages/decision-engine",
    "@shopify/app-bridge-react": "^4.2.4",
    "@shopify/shopify-app-react-router": "^1.1.0",
    "@shopify/shopify-app-session-storage-prisma": "^8.0.0",
    "compression": "^1.7.4",
    "dotenv": "^16.4.5",
    "express": "^5.0.1",
    "helmet": "^8.0.0",
    "morgan": "^1.10.0",
    "ioredis": "^5.9.3",
    "isbot": "^5.1.31",
    "prisma": "^6.19.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router": "^7.12.0",
    "tsx": "^4.19.2",
    "vite-tsconfig-paths": "^5.1.4",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@shopify/api-codegen-preset": "^1.2.0",
    "@shopify/polaris-types": "^1.0.1",
    "@types/autocannon": "^7.12.7",
    "@types/compression": "^1.8.1",
    "@types/eslint": "^9.6.1",
    "@types/express": "^5.0.6",
    "@types/morgan": "^1.9.10",
    "@types/node": "^22.18.8",
    "@types/react": "^18.3.25",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "autocannon": "^8.0.0",
    "eslint": "^8.57.1",
    "eslint-import-resolver-typescript": "^3.10.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^4.6.2",
    "graphql-config": "^5.1.1",
    "prettier": "^3.6.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vite": "^6.3.6",
    "vitest": "^4.0.18"
  },
  "workspaces": [
    "extensions/*"
  ],
  "trustedDependencies": [
    "@shopify/plugin-cloudflare"
  ],
  "overrides": {
    "p-map": "^4.0.0"
  },
  "author": "vardaanarora"
}
