{% comment %}
  Cart Pro — theme app extension block (dynamic runtime).
  Fetches snapshot from /apps/cart-pro/snapshot/v3; loads v1, v2, or v3 runtime based on config.runtimeVersion.
  Enable in Theme customizer > App embeds.
{% endcomment %}
{% schema %}
{
  "name": "Cart Pro V3",
  "target": "body",
  "settings": []
}
{% endschema %}

<div id="cart-pro-root"></div>
<script>
(function() {

  var CACHE_KEY = 'cart-pro-v3-config';

  function loadRuntime(version) {
    var script = document.createElement('script');
    if (version === 'v3') {
      script.src = "{{ 'cart-pro-v3.js' | asset_url }}";
    } else if (version === 'v2') {
      script.src = "{{ 'cart-pro-v2.js' | asset_url }}";
    } else {
      script.src = "{{ 'cart-pro-v1.js' | asset_url }}";
    }
    script.defer = true;
    document.body.appendChild(script);
  }

  function applySnapshot(config) {
    window.__CART_PRO_SNAPSHOT__ = config;
    try {
      sessionStorage.setItem(CACHE_KEY, JSON.stringify(config));
    } catch (e) {}
    if (typeof window.__CART_PRO_RELOAD_CONFIG__ === 'function') {
      window.__CART_PRO_RELOAD_CONFIG__(config);
    }
  }

  function useConfigAndLoad(config) {
    var version = (config && config.runtimeVersion) ? config.runtimeVersion : 'v2';
    applySnapshot(config);
    loadRuntime(version);
  }

  try {
    var cached = sessionStorage.getItem(CACHE_KEY);
    if (cached) {
      var parsed = JSON.parse(cached);
      if (parsed && typeof parsed.runtimeVersion !== 'undefined') {
        useConfigAndLoad(parsed);
        fetch('/apps/cart-pro/snapshot/v3', { credentials: 'same-origin' })
          .then(function(r) { return r.json(); })
          .then(function(config) {
            applySnapshot(config);
          })
          .catch(function() {});
        return;
      }
    }
  } catch (e) {}

  fetch('/apps/cart-pro/snapshot/v3', { credentials: 'same-origin' })
    .then(function(r) { return r.json(); })
    .then(function(config) {
      useConfigAndLoad(config);
    })
    .catch(function(err) {
      console.error('[CartPro] Snapshot load failed', err);
      loadRuntime('v2');
    });

})();
</script>
