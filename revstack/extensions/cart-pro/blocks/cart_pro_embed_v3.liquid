{% comment %}
  Cart Pro — theme app extension block. Always loads the V3 runtime.
  Loads cart-pro-v3.js in parallel with snapshot fetch (CART_FIRST_LOAD_IMPROVEMENT_PLAN Task 3).
  When snapshot resolves, applies config to window.__CART_PRO_SNAPSHOT__; runtime picks it up via mount polling or late apply.
  __CART_PRO_EMBED_INIT__ guard prevents double-run when block is rendered multiple times or script re-executes (e.g. Turbo).
  Enable in Theme customizer > App embeds.
{% endcomment %}
{% schema %}
{
  "name": "Cart Pro V3",
  "target": "body",
  "settings": []
}
{% endschema %}

<div id="cart-pro-root"></div>
<script>
(function() {
  if (window.__CART_PRO_EMBED_INIT__) return;
  window.__CART_PRO_EMBED_INIT__ = true;

  var CACHE_KEY = 'cart-pro-v3-config';

  function loadV3() {
    var script = document.createElement('script');
    script.src = "{{ 'cart-pro-v3.js' | asset_url }}";
    script.defer = true;
    document.body.appendChild(script);
  }

  function applySnapshot(config) {
    window.__CART_PRO_SNAPSHOT__ = config;
    try {
      sessionStorage.setItem(CACHE_KEY, JSON.stringify(config));
    } catch (e) {}
    if (typeof window.__CART_PRO_RELOAD_CONFIG__ === 'function') {
      window.__CART_PRO_RELOAD_CONFIG__(config);
    }
  }

  function fetchSnapshotThenApply() {
    fetch('/apps/cart-pro/snapshot/v3', { credentials: 'same-origin' })
      .then(function(r) {
        if (!r.ok) throw new Error('Snapshot response ' + r.status);
        var ct = r.headers.get('Content-Type') || '';
        if (ct.indexOf('application/json') === -1) throw new Error('Snapshot response is not JSON');
        return r.json();
      })
      .then(function(config) {
        if (config) applySnapshot(config);
      })
      .catch(function(err) {
        console.error('[CartPro] Snapshot load failed', err);
      });
  }

  try {
    var cached = sessionStorage.getItem(CACHE_KEY);
    if (cached) {
      var parsed = JSON.parse(cached);
      if (parsed && typeof parsed === 'object') {
        applySnapshot(parsed);
        fetchSnapshotThenApply();
        loadV3();
        return;
      }
    }
  } catch (e) {}

  loadV3();
  fetchSnapshotThenApply();

})();
</script>
